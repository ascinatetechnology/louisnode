<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | Louis</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      :root {
        --ink-strong: #10233f;
        --ink-soft: #5b6881;
        --accent: #ff7a59;
        --accent-deep: #ec5d3d;
        --surface: rgba(255, 255, 255, 0.72);
        --surface-line: rgba(255, 255, 255, 0.45);
        --glow-a: rgba(255, 122, 89, 0.28);
        --glow-b: rgba(57, 113, 255, 0.18);
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        font-family: "Manrope", sans-serif;
        color: var(--ink-strong);
        background:
          radial-gradient(circle at 15% 20%, var(--glow-a), transparent 30%),
          radial-gradient(circle at 85% 18%, var(--glow-b), transparent 28%),
          linear-gradient(135deg, #f9efe7 0%, #eef3fb 52%, #f7f9fd 100%);
        overflow-x: hidden;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        z-index: 0;
        border-radius: 999px;
        filter: blur(10px);
        pointer-events: none;
      }

      body::before {
        width: 280px;
        height: 280px;
        right: -60px;
        top: 28%;
        background: rgba(255, 122, 89, 0.12);
      }

      body::after {
        width: 220px;
        height: 220px;
        left: -50px;
        bottom: 10%;
        background: rgba(53, 112, 255, 0.12);
      }

      .page-shell {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 40px 0;
      }

      .login-frame {
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid var(--surface-line);
        background: var(--surface);
        backdrop-filter: blur(20px);
        box-shadow: 0 28px 90px rgba(16, 35, 63, 0.16);
      }

      .brand-panel {
        position: relative;
        isolation: isolate;
        min-height: 100%;
        color: #fff;
        background:
          linear-gradient(160deg, rgba(12, 27, 49, 0.94) 0%, rgba(25, 63, 112, 0.92) 60%, rgba(36, 93, 162, 0.9) 100%);
      }

      .brand-panel::before,
      .brand-panel::after {
        content: "";
        position: absolute;
        border-radius: 999px;
        z-index: -1;
      }

      .brand-panel::before {
        width: 220px;
        height: 220px;
        background: rgba(255, 122, 89, 0.22);
        top: -40px;
        right: -60px;
      }

      .brand-panel::after {
        width: 180px;
        height: 180px;
        background: rgba(255, 255, 255, 0.08);
        bottom: -40px;
        left: -30px;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.12);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .hero-title {
        font-size: clamp(2.1rem, 5vw, 3.4rem);
        line-height: 1.05;
        font-weight: 800;
        letter-spacing: -0.04em;
      }

      .hero-copy {
        max-width: 30rem;
        color: rgba(255, 255, 255, 0.76);
        font-size: 1rem;
        line-height: 1.75;
      }

      .mini-stat-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
      }

      .mini-stat {
        padding: 16px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .mini-stat strong {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
      }

      .form-panel {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.78) 0%, rgba(255, 255, 255, 0.9) 100%);
      }

      .panel-label {
        color: var(--ink-soft);
        font-size: 0.9rem;
      }

      .panel-title {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        margin-bottom: 0.6rem;
      }

      .panel-copy {
        color: var(--ink-soft);
        line-height: 1.7;
      }

      .input-shell {
        border-radius: 18px;
        border: 1px solid rgba(16, 35, 63, 0.08);
        background: rgba(247, 249, 253, 0.95);
        padding: 10px 14px;
        transition: 0.2s ease;
      }

      .input-shell:focus-within {
        border-color: rgba(255, 122, 89, 0.46);
        box-shadow: 0 0 0 4px rgba(255, 122, 89, 0.12);
        background: #fff;
      }

      .form-control {
        border: 0;
        background: transparent;
        box-shadow: none !important;
        padding: 0;
        font-size: 1rem;
      }

      .form-control::placeholder {
        color: #98a2b3;
      }

      .form-label {
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 0.55rem;
      }

      .primary-btn {
        border: 0;
        border-radius: 18px;
        padding: 15px 18px;
        font-weight: 800;
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 100%);
        box-shadow: 0 16px 30px rgba(236, 93, 61, 0.24);
      }

      .primary-btn:hover {
        background: linear-gradient(135deg, #ff886a 0%, #de5434 100%);
      }

      .muted-note {
        color: var(--ink-soft);
        font-size: 0.92rem;
      }

      @media (max-width: 767.98px) {
        .brand-panel,
        .form-panel {
          padding: 32px 24px !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="container page-shell">
      <div class="row justify-content-center w-100">
        <div class="col-12 col-xl-11">
          <div class="login-frame">
            <div class="row g-0">
              <div class="col-lg-6 brand-panel p-4 p-md-5 p-xl-5 d-flex flex-column justify-content-between">
                <div>
                  <span class="eyebrow">Louis Admin</span>
                  <h1 class="hero-title mt-4 mb-3">Modern moderation for a safer dating app.</h1>
                  <p class="hero-copy mb-0">
                    Review reports, ban bad actors, restore accounts, and remove abusive profiles from one clean admin experience.
                  </p>
                </div>

                <div class="mini-stat-grid mt-5">
                  <div class="mini-stat">
                    <span class="small text-white-50">Live queue</span>
                    <strong>18</strong>
                    <span class="small text-white-50">Open reports</span>
                  </div>
                  <div class="mini-stat">
                    <span class="small text-white-50">Actioned</span>
                    <strong>11</strong>
                    <span class="small text-white-50">Profiles removed</span>
                  </div>
                </div>
              </div>

              <div class="col-lg-6 form-panel p-4 p-md-5 p-xl-5 d-flex align-items-center">
                <div class="w-100">
                  <h2 class="panel-title">Sign in to Louis Control</h2>
                  <p class="panel-copy mb-4">
                    This is a login screen for now. After submit, it takes you to the admin moderation dashboard UI.
                  </p>

                  <form id="loginForm">
                    <div class="mb-3">
                      <label for="email" class="form-label">Email</label>
                      <div class="input-shell">
                        <input
                          type="email"
                          id="email"
                          name="email"
                          class="form-control"
                          placeholder="admin@louisapp.com"
                          required
                        />
                      </div>
                    </div>

                    <div class="mb-4">
                      <label for="password" class="form-label">Password</label>
                      <div class="input-shell">
                        <input
                          type="password"
                          id="password"
                          name="password"
                          class="form-control"
                          placeholder="Enter secure password"
                          required
                        />
                      </div>
                    </div>

                    <button type="submit" class="btn primary-btn text-white w-100">
                      Continue to Dashboard
                    </button>
                  </form>

                  <div id="message" class="mt-3 fw-semibold" style="display: none"></div>
 
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const loginForm = document.getElementById("loginForm");
      const message = document.getElementById("message");

      loginForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const email = document.getElementById("email").value.trim();
        const password = document.getElementById("password").value.trim();

        if (!email || !password) {
          message.style.display = "block";
          message.className = "mt-3 fw-semibold text-danger";
          message.textContent = "Email and password are required";
          return;
        }

        message.style.display = "block";
        message.className = "mt-3 fw-semibold text-secondary";
        message.textContent = "Signing in...";

        fetch("/admin/login", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          credentials: "same-origin",
          body: JSON.stringify({ email, password })
        })
          .then(async (response) => {
            const data = await response.json();

            if (!response.ok) {
              throw new Error(data.message || "Login failed");
            }

            localStorage.setItem("adminUser", JSON.stringify(data.admin));

            message.className = "mt-3 fw-semibold text-success";
            message.textContent = "Admin login successful. Redirecting...";

            setTimeout(() => {
              window.location.href = "/admin/dashboard";
            }, 700);
          })
          .catch((error) => {
            message.className = "mt-3 fw-semibold text-danger";
            message.textContent = error.message;
          });
      });
    </script>
  </body>
</html>
