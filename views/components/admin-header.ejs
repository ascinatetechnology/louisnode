<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "Admin Dashboard | Louis" %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    :root {
      --ink-strong: #11243f;
      --ink-soft: #627089;
      --surface: rgba(255, 255, 255, 0.84);
      --line: rgba(17, 36, 63, 0.1);
      --accent: #ff7a59;
      --accent-soft: rgba(255, 122, 89, 0.14);
      --success-soft: rgba(42, 157, 143, 0.14);
      --danger-soft: rgba(226, 85, 85, 0.12);
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Manrope", sans-serif;
      color: var(--ink-strong);
      background:
        radial-gradient(circle at top left, rgba(255, 122, 89, 0.18), transparent 24%),
        radial-gradient(circle at 100% 20%, rgba(53, 112, 255, 0.13), transparent 24%),
        linear-gradient(135deg, #fbf1e8 0%, #f3f7fc 55%, #f9fbfe 100%);
    }

    .admin-shell {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      padding: 28px 22px;
      background: rgba(15, 32, 56, 0.96);
      color: #fff;
      box-shadow: 18px 0 48px rgba(17, 36, 63, 0.12);
    }

    .brand {
      font-size: 1.45rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .sidebar-note {
      color: rgba(255, 255, 255, 0.68);
      line-height: 1.65;
      font-size: 0.92rem;
    }

    .nav-btn {
      width: 100%;
      border: 0;
      border-radius: 14px;
      padding: 13px 14px;
      color: rgba(255, 255, 255, 0.78);
      background: transparent;
      font-weight: 800;
      text-align: left;
    }

    .nav-btn.active,
    .nav-btn:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.12);
    }

    .logout-btn {
      width: 100%;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 14px;
      padding: 12px 14px;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-weight: 800;
    }

    .content {
      padding: 30px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 22px;
    }

    .page-title {
      margin: 0;
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .page-copy {
      margin: 6px 0 0;
      color: var(--ink-soft);
    }

    .glass-card {
      background: var(--surface);
      border: 1px solid rgba(255, 255, 255, 0.42);
      box-shadow: 0 24px 70px rgba(17, 36, 63, 0.11);
      backdrop-filter: blur(18px);
    }

    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    .metric-card,
    .panel-card {
      border-radius: 24px;
      padding: 22px;
    }

    .metric-label {
      color: var(--ink-soft);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 800;
    }

    .metric-value {
      font-size: 2.2rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin-top: 6px;
    }

    .panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
    }

    .panel-title {
      margin: 0;
      font-size: 1.18rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .panel-copy,
    .profile-meta {
      color: var(--ink-soft);
      font-size: 0.92rem;
    }

    .table-wrap {
      border-radius: 18px;
      overflow: auto;
      border: 1px solid var(--line);
      background: rgba(248, 250, 253, 0.82);
    }

    .table {
      margin: 0;
      min-width: 760px;
    }

    .table th {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--ink-soft);
      background: rgba(255, 255, 255, 0.72);
    }

    .table td,
    .table th {
      padding: 14px 16px;
      vertical-align: middle;
      border-color: var(--line);
    }

    .action-btn,
    .solid-btn {
      border: 0;
      border-radius: 12px;
      padding: 10px 13px;
      font-size: 0.86rem;
      font-weight: 800;
    }

    .solid-btn {
      background: linear-gradient(135deg, var(--accent) 0%, #e95b3b 100%);
      color: white;
      box-shadow: 0 16px 28px rgba(233, 91, 59, 0.22);
    }

    .danger-btn {
      background: var(--danger-soft);
      color: #bf3f3f;
    }

    .success-btn {
      background: var(--success-soft);
      color: #1a7f71;
    }

    .neutral-btn {
      background: rgba(17, 36, 63, 0.08);
      color: var(--ink-strong);
    }

    .status-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 800;
      padding: 7px 11px;
      background: var(--accent-soft);
      color: #bf492f;
    }

    .profile-card {
      border-radius: 18px;
      padding: 18px;
      border: 1px solid var(--line);
      background: rgba(249, 250, 253, 0.92);
    }

    .view-section {
      display: none;
    }

    .view-section.active {
      display: block;
    }

    .form-control,
    .form-select {
      border-radius: 12px;
      border-color: var(--line);
      padding: 10px 12px;
    }

    .form-label {
      font-size: 0.8rem;
      font-weight: 800;
      color: var(--ink-soft);
    }

    .empty-state {
      padding: 28px 18px;
      text-align: center;
      color: var(--ink-soft);
    }

    @media (max-width: 991.98px) {
      .admin-shell {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
        height: auto;
      }

      .metric-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 575.98px) {
      .content {
        padding: 18px;
      }

      .metric-grid {
        grid-template-columns: 1fr;
      }

      .topbar,
      .panel-head {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>
